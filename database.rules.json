{
  "rules": {
    "storesBySubdomain": {
      ".read": true,
      "$subdomain": {
        ".write": "auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "store": {
          ".read": true,
          ".write": "auth != null && auth.uid === $uid"
        },
        "storeProducts": {
          ".read": true,
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }
  }
}



